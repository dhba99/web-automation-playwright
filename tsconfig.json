{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",

    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "types": ["node", "playwright"],

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "outDir": "dist"
  },

  "include": [
    "features/**/*.ts",
    "pages/**/*.ts",
    "support/**/*.ts"
  ],

  "exclude": [
    "node_modules"
  ]
}